{
    "version": "1.1.2",
    "description": "A free and open-source multi-platform parametric 3D modeler.",
    "homepage": "https://www.freecad.org",
    "license": {
        "identifier": "LGPL-2.1-or-later",
        "url": "https://github.com/FreeCAD/FreeCAD/blob/HEAD/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/FreeCAD/FreeCAD/releases/download/1.1.2/FreeCAD_1.1.2-Windows-x86_64-py311.7z",
            "hash": "76d848d5a8baad129e2700ef53bd08525c3063ea14036edffef6b41b9eaab5ef"
        }
    },
    "pre_install": "pushd $dir ; mv */* . ; rm FreeCAD_* ; popd",
    "bin": "bin\\FreeCADCmd.exe",
    "shortcuts": [
        [
            "bin\\FreeCAD.exe",
            "FreeCAD"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/FreeCAD/FreeCAD/releases/latest",
        "jsonpath": "$.assets[?(@.name =~ /Win.+\\.7z$/i)].browser_download_url",
        "regex": "(?i)download/(?<tag>[^/]+)/(?<name>FreeCAD[^\\d]([0-9a-f.-]+)(?:-conda)?-Win.+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/FreeCAD/FreeCAD/releases/download/$matchTag/$matchName"
            }
        },
        "hash": {
            "url": "$url-SHA256.txt",
            "regex": "(?s)$basename.*?$sha256"
        }
    }
}
